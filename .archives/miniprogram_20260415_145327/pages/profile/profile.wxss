/* 个人中心页面样式 */

.page-profile {
  min-height: 100vh;
  background-color: var(--color-bg-dark);
  padding: 30rpx;
}

.page-header {
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

/* 登录提示 */
.login-required {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 50rpx;
  text-align: center;
}

.login-title {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 60rpx;
}

/* 身体档案卡片 */
.profile-card {
  margin-bottom: 40rpx;
}

.profile-inputs {
  display: flex;
  gap: 30rpx;
}

.profile-input {
  flex: 1;
}

.profile-input .input {
  margin-top: 12rpx;
}

/* 功能列表 */
.list {
  margin-bottom: 30rpx;
}

.list-item-arrow {
  font-size: 40rpx;
  color: var(--color-text-secondary);
}

.logout {
  color: #e74c3c !important;
}

.logout text,
.logout > text {
  color: #e74c3c !important;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 60rpx 0;
}

.version-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
