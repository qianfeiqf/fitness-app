<!-- 训练历史列表页 -->

<view class="page-history">
  <!-- 顶部统计 -->
  <view class="history-header">
    <view class="history-stat">
      <text class="history-stat-num">{{totalCount}}</text>
      <text class="history-stat-label">累计训练(次)</text>
    </view>
    <view class="history-stat-divider"></view>
    <view class="history-stat">
      <text class="history-stat-num">{{totalVolume}}</text>
      <text class="history-stat-label">累计容量(kg)</text>
    </view>
  </view>

  <!-- 时间筛选 -->
  <mp-tabs tabs="{{periodTabs}}" active-tab="{{periodTabIndex}}" bind:change="onPeriodTabChange" />

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="skeleton-row" wx:for="{{[1,2,3,4,5]}}" wx:key="*this"></view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{filteredSessions.length === 0}}" class="empty-wrap">
    <text class="empty-icon">📋</text>
    <text class="empty-title">暂无训练记录</text>
    <text class="empty-desc">完成训练后，记录会自动出现在这里</text>
  </view>

  <!-- 历史列表 -->
  <view wx:else class="history-list">
    <view
      wx:for="{{filteredSessions}}"
      wx:key="id"
      class="history-item"
      bindtap="onViewDetail"
      data-session-id="{{item.id}}"
      hover-class="item-pressed"
    >
      <view class="item-left">
        <text class="item-date">{{item.dateStr}}</text>
        <text class="item-plan">{{item.plan_name || '自由训练'}}</text>
      </view>
      <view class="item-right">
        <view class="item-metric">
          <text class="metric-value">{{item.volume}}</text>
          <text class="metric-unit">kg</text>
        </view>
        <view class="item-meta">
          <text>{{item.setCount}}组 · {{item.duration}}</text>
        </view>
      </view>
      <text class="item-arrow">›</text>
    </view>
  </view>
</view>
