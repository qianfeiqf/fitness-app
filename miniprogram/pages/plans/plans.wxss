/**
 * 计划管理页面样式 — WeUI 扁平风格
 */

.page-plans {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding: 40rpx;
  padding-top: calc(40rpx + env(safe-area-inset-top));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* =====================
   激活的计划卡片
   ===================== */
.active-plan {
  background: #FFFFFF;
  border: 1rpx solid #E5E5E5;
  border-radius: 24rpx;
  padding: 30rpx;
}

/* =====================
   章节
   ===================== */
.section {
  margin-top: 50rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.section-hint {
  font-size: 22rpx;
  color: #666666;
}

/* 新建按钮 */
.btn-new {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border: 2rpx solid #1A1A1A;
  border-radius: 9999rpx;
}

/* 操作按钮组 */
.section-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 计划推荐按钮 */
.btn-recommend {
  font-size: 26rpx;
  color: #07C160;
  font-weight: 600;
  padding: 8rpx 20rpx;
  background: rgba(7, 193, 96, 0.08);
  border-radius: 9999rpx;
}

.btn-recommend:active {
  opacity: 0.7;
}

/* 推荐计划列表 */
.recommend-list {
  margin-bottom: 32rpx;
}

.recommend-empty {
  text-align: center;
  padding: 48rpx 0;
}

.recommend-empty-text {
  font-size: 28rpx;
  color: #999999;
}

.recommend-card {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.15s ease;
}

.recommend-card:active {
  background: #EEEEEE;
}

.recommend-card.selected {
  background: #F0F0F0;
  border-color: #1A1A1A;
}

.recommend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.recommend-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.recommend-tags {
  display: flex;
  gap: 8rpx;
}

.recommend-desc {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.recommend-features {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.feature-tag {
  font-size: 20rpx;
  color: #1A1A1A;
  background: #E5E5E5;
  padding: 4rpx 12rpx;
  border-radius: 9999rpx;
}

.recommend-check {
  font-size: 24rpx;
  color: #1A1A1A;
  font-weight: 600;
  margin-top: 10rpx;
}

/* 标签样式 */
.tag {
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 14rpx;
  border-radius: 9999rpx;
  background: #E5E5E5;
  color: #1A1A1A;
}

.tag.beginner { background: rgba(7, 193, 96, 0.1); color: #07C160; }
.tag.intermediate { background: rgba(0, 0, 0, 0.06); color: #1A1A1A; }
.tag.advanced { background: rgba(0, 0, 0, 0.1); color: #1A1A1A; }

/* 空状态卡片 */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background: #FFFFFF;
  border: 2rpx dashed rgba(0, 0, 0, 0.15);
  border-radius: 24rpx;
}

.empty-card-icon {
  font-size: 48rpx;
  color: #1A1A1A;
  font-weight: 300;
  margin-bottom: 16rpx;
}

.empty-card-text {
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 600;
}

/* =====================
   计划列表
   ===================== */
.plan-list {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid #E5E5E5;
}

.plan-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: none;
  transition: all 0.15s ease;
}

.plan-item:active {
  background-color: rgba(0, 0, 0, 0.02);
}

.plan-item:last-child {
  border-bottom: none;
}

.plan-item.active {
  background-color: #F5F5F5;
}

.plan-item.active .plan-name {
  color: #1A1A1A;
  font-weight: 700;
}

.plan-info {
  flex: 1;
  min-width: 0;
}

.plan-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  margin-bottom: 4rpx;
}

.plan-desc {
  font-size: 24rpx;
  color: #666666;
  display: block;
  margin-bottom: 6rpx;
}

.plan-meta {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.plan-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.arrow-icon {
  font-size: 48rpx;
  color: #CCCCCC;
}

/* 危险按钮 */
.btn-ghost.danger {
  color: #FA5151 !important;
}

/* =====================
   模板列表
   ===================== */
.template-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.template-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  min-height: 88rpx;
  border: 1rpx solid #E5E5E5;
}

.template-item:active {
  background-color: #F8F8F8;
}

.template-info {
  flex: 1;
  min-width: 0;
}

.template-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 6rpx;
}

.template-desc {
  font-size: 24rpx;
  color: #666666;
  display: block;
  margin-bottom: 10rpx;
}

.template-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.template-difficulty {
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 14rpx;
  border-radius: 9999rpx;
}

.template-days {
  font-size: 22rpx;
  color: #666666;
  padding: 6rpx 14rpx;
  background-color: #F5F5F5;
  border-radius: 9999rpx;
}

.tag-green,
.tag-yellow,
.tag-red {
  color: #1A1A1A !important;
  background-color: #F0F0F0 !important;
}

/* =====================
   模板详情弹窗
   ===================== */
.template-detail-modal {
  width: 650rpx;
  max-height: 85vh;
  overflow-y: auto;
  background-color: #FFFFFF !important;
  border: none !important;
}

.detail-header {
  margin-bottom: 28rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 16rpx;
}

.detail-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 32rpx;
}

.detail-exercises {
  margin-top: 28rpx;
}

.detail-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: none;
}

/* 训练日区块 */
.day-block {
  margin-bottom: 24rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx;
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: none;
}

.day-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.day-count {
  font-size: 24rpx;
  color: #999999;
}

/* 动作行 */
.exercise-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: none;
}

.exercise-row:last-child {
  border-bottom: none;
}

.exercise-name {
  font-size: 28rpx;
  color: #1A1A1A;
  flex: 1;
  font-weight: 500;
}

.exercise-sets {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 600;
  background-color: #F0F0F0;
  padding: 6rpx 16rpx;
  border-radius: 9999rpx;
  margin-left: 16rpx;
}

/* =====================
   输入框
   ===================== */
.input-wrapper {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #1A1A1A;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  background-color: #FFFFFF;
  border: 1rpx solid #E5E5E5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1A1A1A;
  box-sizing: border-box;
}

.input::placeholder {
  color: #B0B0B0;
}

/* =====================
   空状态
   ===================== */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #666666;
  display: block;
}

/* WeUI 组件样式覆盖 */
mp-tabs {
  margin-bottom: 16rpx;
}

.filter-hint {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 20rpx;
  padding: 12rpx 20rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
}

/* 详细介绍弹窗 */
.template-intro-modal {
  width: 680rpx;
  max-height: 85vh;
  overflow-y: auto;
  background-color: #FFFFFF !important;
  border: none !important;
}

.intro-header {
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: none;
}

.intro-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 16rpx;
}

.intro-tags {
  display: flex;
  gap: 16rpx;
}

.intro-section {
  margin-bottom: 28rpx;
}

.intro-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #666666;
  display: block;
  line-height: 1.7;
}
