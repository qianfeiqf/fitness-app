/**
 * 刻度拨盘 — WeUI 扁平风格
 * 容器 + DIN 数字 + 中心指示线
 *
 * 视觉反馈逻辑：
 * - 容器用边框替代阴影
 * - 滚动时中心项放大加粗，周围项缩小变灰
 * - 松手后 snap 回弹到最近项，有"咔哒"质感
 */

.dial-picker {
  position: relative;
  width: 100%;
  height: 400rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: #FFFFFF;
  /* 扁平风格 — 边框替代内凹阴影 */
  border: 1rpx solid #E5E5E5;
}

/* 渐变遮罩 — 白→透明，营造凹槽深度 */
.dial-mask {
  position: absolute;
  left: 0;
  right: 0;
  height: 120rpx;
  z-index: 2;
  pointer-events: none;
}

.dial-mask-top {
  top: 0;
  background: linear-gradient(to bottom, #FFFFFF 0%, rgba(255, 255, 255, 0) 100%);
}

.dial-mask-bottom {
  bottom: 0;
  background: linear-gradient(to top, #FFFFFF 0%, rgba(255, 255, 255, 0) 100%);
}

/* 中心指示线 — 在选中项底部，而非穿过文字 */
.dial-center-indicator {
  position: absolute;
  /* 选中项中心在 50%，文字底部 ≈ +20rpx（文字实际高度小于容器 80rpx） */
  top: calc(50% + 20rpx);
  left: 10%;
  right: 10%;
  z-index: 3;
  pointer-events: none;
}

.dial-center-line {
  width: 100%;
  height: 3rpx;
  background: #1A1A1A;
  border-radius: 2rpx;
}

/* scroll-view 本体 — snap 管手势吸附，scroll-top 管程序化定位，互不干扰 */
.dial-scroll {
  width: 100%;
  height: 100%;
  scroll-snap-type: y mandatory;
}

/* 上下留白 — 容器半高减去半项高，让首尾项可以居中 */
.dial-spacer {
  height: 160rpx;
}

/* 单项 */
.dial-item {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  scroll-snap-align: center;
}

/* 默认状态 — 灰色较小 */
.dial-item-value {
  font-family: 'DIN Alternate', system-ui, sans-serif;
  font-size: 36rpx;
  font-weight: 400;
  color: #B0B0B0;
  font-variant-numeric: tabular-nums;
  transition: font-size 0.15s ease, color 0.15s ease, font-weight 0.15s ease;
}

/* 选中状态 — 黑色大号加粗 */
.dial-item--active .dial-item-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #1A1A1A;
}

/* 单位文字 */
.dial-unit {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  font-weight: 500;
  color: #999999;
  z-index: 4;
  pointer-events: none;
}
