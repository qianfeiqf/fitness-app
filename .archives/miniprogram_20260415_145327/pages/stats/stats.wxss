/* 统计页面样式 - UI/UX优化版本 */
/* 设计规范: 数据可视化, 深色主题, 无障碍触摸 */

page {
  background-color: var(--color-bg-dark);
}

.page-stats {
  min-height: 100vh;
  background-color: var(--color-bg-dark);
  padding: 30rpx;
  padding-top: calc(30rpx + env(safe-area-inset-top));
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.page-header {
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: -0.5rpx;
}

/* =====================
   章节
   ===================== */
.section {
  margin-bottom: 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.total-volume {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  font-variant-numeric: tabular-nums;
}

/* =====================
   三大项
   ===================== */
.big-three-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.big-three-card {
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.card-pressed {
  opacity: 0.9;
  transform: scale(0.98);
}

.card-accent {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
}

.big-three-card .exercise-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.rm-display {
  margin-bottom: 12rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
}

.rm-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  font-variant-numeric: tabular-nums;
}

.rm-unit {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.rm-trend {
  margin-bottom: 12rpx;
}

.trend-badge {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.trend-badge.up {
  background-color: rgba(46, 204, 113, 0.15);
  color: var(--color-success);
}

.trend-badge.down {
  background-color: rgba(231, 76, 60, 0.15);
  color: var(--color-danger);
}

.trend-badge.flat {
  background-color: rgba(160, 160, 160, 0.15);
  color: var(--color-text-secondary);
}

.trend-arrow {
  font-size: 20rpx;
}

.trend-value {
  font-variant-numeric: tabular-nums;
}

.best-rm {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.best-label {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.best-value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}

/* =====================
   容量图
   ===================== */
.volume-chart {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 200rpx;
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
}

.volume-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.volume-bar-wrapper {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  min-height: 4rpx;
}

.volume-bar {
  width: 32rpx;
  background-color: var(--color-bg-input);
  border-radius: 6rpx;
  min-height: 4rpx;
  transition: height 0.4s ease, background-color 0.2s ease;
}

.volume-bar.active {
  background-color: var(--color-primary);
}

.volume-day {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 12rpx;
  font-weight: 500;
}

/* =====================
   空状态
   ===================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  text-align: center;
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
}

.empty-visual {
  margin-bottom: 24rpx;
}

.empty-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  background-color: var(--color-bg-input);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 48rpx;
  color: var(--color-text-secondary);
}

.empty-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* =====================
   PR列表
   ===================== */
.pr-list {
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  overflow: hidden;
}

.pr-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid var(--color-divider);
  transition: background-color 0.15s ease;
}

.item-pressed {
  background-color: rgba(255, 255, 255, 0.05);
}

.pr-item:last-child {
  border-bottom: none;
}

.pr-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.pr-icon {
  font-size: 28rpx;
  color: #1a1a2e;
  font-weight: 700;
}

.pr-info {
  flex: 1;
  min-width: 0;
}

.pr-exercise {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.pr-date {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
}

.pr-value {
  text-align: right;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.pr-value .value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
  font-variant-numeric: tabular-nums;
}

.pr-value .type {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 4rpx;
}
