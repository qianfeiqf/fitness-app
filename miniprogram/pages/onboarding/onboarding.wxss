/* 新用户引导页面样式 */

.page-onboarding {
  min-height: 100vh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  padding-top: 40rpx;
  box-sizing: border-box;
}

.redirect-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.redirect-text {
  font-size: 28rpx;
  color: #999999;
}
