<wxs module="wxs">
/**
 * 格式化时间显示 (MM:SS)
 */
function formatTime(seconds) {
  if (typeof seconds !== 'number' || seconds < 0) {
    return '0:00';
  }
  var mins = Math.floor(seconds / 60);
  var secs = seconds % 60;
  return mins + ':' + (secs < 10 ? '0' + secs : secs);
}

module.exports = {
  formatTime: formatTime
};
</wxs>