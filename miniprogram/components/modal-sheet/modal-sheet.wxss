.modal-sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  animation: fadeIn 0.2s ease-out;
}

.modal-sheet-container {
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease-out;
}

.modal-sheet-handle {
  width: 48rpx;
  height: 6rpx;
  background: #E0E0E0;
  border-radius: 3rpx;
  margin: 0 auto 24rpx;
}

.modal-sheet-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  text-align: center;
  margin-bottom: 8rpx;
}

.modal-sheet-desc {
  font-size: 26rpx;
  color: #888888;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-sheet-content {
  margin-bottom: 32rpx;
}

.modal-sheet-actions {
  display: flex;
  gap: 20rpx;
}

.modal-sheet-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: opacity 0.15s ease;
}

.modal-sheet-btn-cancel {
  background: #F5F5F5;
  color: #666666;
  border: 1rpx solid #E5E5E5;
}

.modal-sheet-btn-cancel:active {
  background-color: #EDEDED;
}

.modal-sheet-btn-confirm {
  background: #07C160;
  color: #FFFFFF;
}

.modal-sheet-btn-confirm:active {
  opacity: 0.85;
}

.modal-sheet-btn-confirm.disabled {
  opacity: 0.5;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(100%); }
  to { opacity: 1; transform: translateY(0); }
}
