<!-- 计划管理页面 -->

<view class="page-plans">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">训练计划</text>
    <button class="btn btn-sm btn-primary" bindtap="onShowCreateModal">新建计划</button>
  </view>

  <!-- 训练计划列表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">我的计划</text>
    </view>

    <view wx:if="{{plans.length === 0}}" class="empty-state">
      <text class="empty-title">暂无计划</text>
      <text class="empty-desc">创建一个新计划或从经典计划复制</text>
    </view>

    <view wx:else class="plan-list">
      <view wx:for="{{plans}}"
            wx:key="id"
            class="plan-item {{item.status === 'active' ? 'active' : ''}}"
            bindtap="onViewPlanDetail"
            data-plan-id="{{item.id}}">
        <view class="plan-info">
          <text class="plan-name">{{item.name}}</text>
          <text wx:if="{{item.description}}" class="plan-desc">{{item.description}}</text>
          <text class="plan-meta">
            {{item.status === 'active' ? '进行中' : item.status === 'archived' ? '已归档' : '草稿'}}
          </text>
        </view>
        <view class="plan-right">
          <button class="btn btn-sm btn-ghost"
                  catchtap="onShowClonePlanModal"
                  data-plan-id="{{item.id}}">
            复制
          </button>
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 经典计划 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">经典计划</text>
      <text class="section-hint">点击查看详情，复制到我的计划</text>
    </view>

    <!-- 难度筛选标签 -->
    <view class="filter-tabs">
      <view
        wx:for="{{filterDifficultyOptions}}"
        wx:key="this"
        class="filter-tab {{filterDifficulty === item ? 'active' : ''}} {{item !== '' ? 'filter-tab-' + item : ''}}"
        bindtap="onFilterByDifficulty"
        data-difficulty="{{item}}"
      >
        <text>{{item === '' ? '全部' : item}}</text>
      </view>
    </view>

    <!-- 训练天数筛选标签 -->
    <view class="filter-tabs">
      <view
        wx:for="{{filterOptions}}"
        wx:key="this"
        class="filter-tab {{filterDays === item ? 'active' : ''}}"
        bindtap="onFilterByDays"
        data-days="{{item}}"
      >
        <text>{{item === 0 ? '全部' : item + '天'}}</text>
      </view>
    </view>

    <!-- 筛选结果提示 -->
    <view wx:if="{{filterDays > 0 || filterDifficulty !== ''}}" class="filter-hint">
      <text>共找到 {{filteredTemplates.length}} 个计划</text>
    </view>

    <view class="template-list">
      <view wx:for="{{filteredTemplates}}"
            wx:key="id"
            class="template-item"
            bindtap="onViewTemplateDetail"
            data-template-id="{{item.id}}">
        <view class="template-info">
          <text class="template-name">{{item.name}}</text>
          <text class="template-desc">{{item.description}}</text>
          <view class="template-tags">
            <text class="template-difficulty {{item.difficulty === '入门' ? 'tag-green' : item.difficulty === '进阶' ? 'tag-red' : 'tag-yellow'}}">{{item.difficulty}}</text>
            <text class="template-days">每周{{item.training_days}}天</text>
          </view>
        </view>
        <button class="btn btn-sm btn-primary"
                catchtap="onShowCloneTemplateModal"
                data-template-id="{{item.id}}">
          复制
        </button>
      </view>

      <!-- 无筛选结果 -->
      <view wx:if="{{filteredTemplates.length === 0}}" class="empty-state">
        <text class="empty-title">暂无符合条件的计划</text>
        <text class="empty-desc">试试调整筛选条件</text>
      </view>
    </view>
  </view>

  <!-- 经典计划详情弹窗 -->
  <view wx:if="{{showTemplateDetailModal}}" class="modal-mask" bindtap="onCloseTemplateDetail">
    <view class="modal-content template-detail-modal" catchtap="noop">
      <view class="detail-header">
        <text class="detail-title">{{selectedTemplate.name}}</text>
        <view class="detail-tags">
          <text class="template-difficulty {{selectedTemplate.difficulty === '入门' ? 'tag-green' : selectedTemplate.difficulty === '进阶' ? 'tag-red' : 'tag-yellow'}}">{{selectedTemplate.difficulty}}</text>
          <text class="template-days">每周{{selectedTemplate.training_days}}天</text>
        </view>
      </view>
      <text class="detail-desc">{{selectedTemplate.description}}</text>

      <!-- 了解更多按钮 -->
      <button class="btn btn-ghost btn-block" bindtap="onShowTemplateIntro" data-template-id="{{selectedTemplate.id}}">
        了解更多
      </button>

      <view class="detail-exercises">
        <text class="detail-section-title">训练安排</text>
        <view wx:for="{{templateExerciseList}}"
              wx:key="day"
              class="day-block">
          <view class="day-header">
            <text class="day-label">{{item.dayLabel}}</text>
            <text class="day-count">{{item.exercises.length}}个动作</text>
          </view>
          <view wx:for="{{item.exercises}}"
                wx:for-item="ex"
                wx:key="exercise_id"
                class="exercise-row">
            <text class="exercise-name">{{ex.name}}</text>
            <text class="exercise-sets">{{ex.target_sets}}组 × {{ex.target_reps}}次</text>
          </view>
        </view>
      </view>

      <view class="modal-actions">
        <button class="btn btn-secondary" bindtap="onCloseTemplateDetail">关闭</button>
        <button class="btn btn-primary" bindtap="onShowCloneTemplateModal" data-template-id="{{selectedTemplate.id}}">复制此计划</button>
      </view>
    </view>
  </view>

  <!-- 经典计划详细介绍弹窗 -->
  <view wx:if="{{showTemplateIntroModal}}" class="modal-mask" bindtap="onCloseTemplateIntro">
    <view class="modal-content template-intro-modal" catchtap="noop">
      <view class="intro-header">
        <text class="intro-title">{{selectedTemplate.name}}</text>
        <view class="intro-tags">
          <text class="template-difficulty {{selectedTemplate.difficulty === '入门' ? 'tag-green' : selectedTemplate.difficulty === '进阶' ? 'tag-red' : 'tag-yellow'}}">{{selectedTemplate.difficulty}}</text>
          <text class="template-days">每周{{selectedTemplate.training_days}}天</text>
        </view>
      </view>

      <view class="intro-section">
        <text class="intro-section-title">计划简介</text>
        <text class="intro-text">{{selectedTemplate.description}}</text>
      </view>

      <view class="intro-section">
        <text class="intro-section-title">产生背景</text>
        <text class="intro-text">{{selectedTemplate.background}}</text>
      </view>

      <view class="intro-section">
        <text class="intro-section-title">适用对象</text>
        <text class="intro-text">{{selectedTemplate.suitable_for}}</text>
      </view>

      <view class="intro-section">
        <text class="intro-section-title">训练频率</text>
        <text class="intro-text">每周 {{selectedTemplate.training_days}} 天训练，{{7 - selectedTemplate.training_days}} 天休息</text>
      </view>

      <view class="intro-section" wx:if="{{selectedTemplate.notes}}">
        <text class="intro-section-title">注意事项</text>
        <text class="intro-text">{{selectedTemplate.notes}}</text>
      </view>

      <view class="modal-actions">
        <button class="btn btn-secondary" bindtap="onCloseTemplateIntro">关闭</button>
        <button class="btn btn-primary" bindtap="onShowCloneTemplateModal" data-template-id="{{selectedTemplate.id}}">复制此计划</button>
      </view>
    </view>
  </view>

  <!-- 创建计划弹窗 -->
  <view wx:if="{{showCreateModal}}" class="modal-mask" bindtap="onCancelCreate">
    <view class="modal-content" catchtap="noop">
      <text class="modal-title">新建计划</text>

      <view class="input-wrapper">
        <text class="input-label">计划名称</text>
        <input class="input"
               placeholder="输入计划名称"
               value="{{newPlanName}}"
               bindinput="onInputPlanName" />
      </view>

      <view class="modal-actions">
        <button class="btn btn-secondary" bindtap="onCancelCreate">取消</button>
        <button class="btn btn-primary" bindtap="onCreatePlan">创建</button>
      </view>
    </view>
  </view>

  <!-- 复制计划弹窗 -->
  <view wx:if="{{showCloneModal}}" class="modal-mask" bindtap="onCancelClone">
    <view class="modal-content" catchtap="noop">
      <text class="modal-title">复制计划</text>
      <text class="modal-desc">为复制的计划指定一个新名称</text>

      <view class="input-wrapper">
        <text class="input-label">计划名称</text>
        <input class="input"
               placeholder="输入计划名称"
               value="{{newPlanName}}"
               bindinput="onInputPlanName" />
      </view>

      <view class="modal-actions">
        <button class="btn btn-secondary" bindtap="onCancelClone">取消</button>
        <button class="btn btn-primary" bindtap="onConfirmClone">确认复制</button>
      </view>
    </view>
  </view>
</view>
