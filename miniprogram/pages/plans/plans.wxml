<!-- 计划管理页面 -->

<view class="page-plans">
  <!-- 训练计划列表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">我的计划</text>
      <view class="section-actions">
        <text class="btn-recommend" bindtap="onShowRecommend">计划推荐</text>
        <text wx:if="{{plans.length > 0}}" class="btn-new" bindtap="onNavigateToCreate">新建</text>
      </view>
    </view>

    <view wx:if="{{plans.length === 0}}" class="empty-card" bindtap="onNavigateToCreate">
      <text class="empty-card-icon">+</text>
      <text class="empty-card-text">新建计划</text>
    </view>

    <view wx:else class="plan-list">
      <view wx:for="{{plans}}"
            wx:key="id"
            class="plan-item {{item.status === 'active' ? 'active' : ''}}"
            bindtap="onViewPlanDetail"
            data-plan-id="{{item.id}}">
        <view class="plan-info">
          <text class="plan-name">{{item.name}}</text>
          <text wx:if="{{item.description}}" class="plan-desc">{{item.description}}</text>
          <text class="plan-meta">
            {{item.status === 'active' ? '进行中' : item.status === 'archived' ? '已归档' : '草稿'}}
          </text>
        </view>
        <view class="plan-right">
          <button class="btn btn-sm btn-ghost"
                  catchtap="onShowClonePlanModal"
                  data-plan-id="{{item.id}}">
            复制
          </button>
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 经典计划 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">经典计划</text>
      <text class="section-hint">点击查看详情，复制到我的计划</text>
    </view>

    <!-- 难度筛选 -->
    <mp-tabs tabs="{{difficultyTabs}}" active-tab="{{difficultyTabIndex}}" bind:change="onDifficultyTabChange" />

    <!-- 训练天数筛选 -->
    <mp-tabs tabs="{{daysTabs}}" active-tab="{{daysTabIndex}}" bind:change="onDaysTabChange" />

    <!-- 筛选结果提示 -->
    <view wx:if="{{filterDays > 0 || filterDifficulty !== ''}}" class="filter-hint">
      <text>共找到 {{filteredTemplates.length}} 个计划</text>
    </view>

    <view class="template-list">
      <view wx:for="{{filteredTemplates}}"
            wx:key="id"
            class="template-item"
            bindtap="onViewTemplateDetail"
            data-template-id="{{item.id}}">
        <view class="template-info">
          <text class="template-name">{{item.name}}</text>
          <text class="template-desc">{{item.description}}</text>
          <view class="template-tags">
            <text class="template-difficulty {{item.difficulty === '入门' ? 'tag-green' : item.difficulty === '进阶' ? 'tag-red' : 'tag-yellow'}}">{{item.difficulty}}</text>
            <text class="template-days">每周{{item.training_days}}天</text>
          </view>
        </view>
        <button class="btn btn-sm btn-primary"
                catchtap="onShowCloneTemplateModal"
                data-template-id="{{item.id}}">
          复制
        </button>
      </view>

      <!-- 无筛选结果 -->
      <view wx:if="{{filteredTemplates.length === 0}}" class="empty-state">
        <text class="empty-title">暂无符合条件的计划</text>
        <text class="empty-desc">试试调整筛选条件</text>
      </view>
    </view>
  </view>

  <!-- 经典计划详情弹窗 -->
  <modal-sheet
    visible="{{showTemplateDetailModal}}"
    title="{{selectedTemplate.name}}"
    confirmText="复制此计划"
    cancelText="关闭"
    bind:confirm="onShowCloneTemplateFromDetail"
    bind:cancel="onCloseTemplateDetail"
    bind:close="onCloseTemplateDetail"
  >
    <view class="detail-tags" style="margin-bottom:16rpx;">
      <text class="template-difficulty {{selectedTemplate.difficulty === '入门' ? 'tag-green' : selectedTemplate.difficulty === '进阶' ? 'tag-red' : 'tag-yellow'}}">{{selectedTemplate.difficulty}}</text>
      <text class="template-days">每周{{selectedTemplate.training_days}}天</text>
    </view>
    <text class="detail-desc">{{selectedTemplate.description}}</text>

    <view class="btn btn-ghost btn-block" style="margin:16rpx 0;" bindtap="onShowTemplateIntro">
      了解更多 ›
    </view>

    <view class="detail-exercises">
      <text class="detail-section-title">训练安排</text>
      <view wx:for="{{templateExerciseList}}"
            wx:key="day"
            class="day-block">
        <view class="day-header">
          <text class="day-label">{{item.dayLabel}}</text>
          <text class="day-count">{{item.exercises.length}}个动作</text>
        </view>
        <view wx:for="{{item.exercises}}"
              wx:for-item="ex"
              wx:key="exercise_id"
              class="exercise-row">
          <text class="exercise-name">{{ex.name}}</text>
          <text class="exercise-sets">{{ex.target_sets}}组 × {{ex.target_reps}}次</text>
        </view>
      </view>
    </view>
  </modal-sheet>

  <!-- 经典计划详细介绍弹窗 -->
  <modal-sheet
    visible="{{showTemplateIntroModal}}"
    title="{{selectedTemplate.name}}"
    confirmText="复制此计划"
    cancelText="关闭"
    bind:confirm="onShowCloneTemplateFromIntro"
    bind:cancel="onCloseTemplateIntro"
    bind:close="onCloseTemplateIntro"
  >
    <view class="intro-tags" style="margin-bottom:24rpx;">
      <text class="template-difficulty {{selectedTemplate.difficulty === '入门' ? 'tag-green' : selectedTemplate.difficulty === '进阶' ? 'tag-red' : 'tag-yellow'}}">{{selectedTemplate.difficulty}}</text>
      <text class="template-days">每周{{selectedTemplate.training_days}}天</text>
    </view>

    <view class="intro-section">
      <text class="intro-section-title">计划简介</text>
      <text class="intro-text">{{selectedTemplate.description}}</text>
    </view>

    <view class="intro-section">
      <text class="intro-section-title">产生背景</text>
      <text class="intro-text">{{selectedTemplate.background}}</text>
    </view>

    <view class="intro-section">
      <text class="intro-section-title">适用对象</text>
      <text class="intro-text">{{selectedTemplate.suitable_for}}</text>
    </view>

    <view class="intro-section">
      <text class="intro-section-title">训练频率</text>
      <text class="intro-text">每周 {{selectedTemplate.training_days}} 天训练，{{7 - selectedTemplate.training_days}} 天休息</text>
    </view>

    <view class="intro-section" wx:if="{{selectedTemplate.notes}}">
      <text class="intro-section-title">注意事项</text>
      <text class="intro-text">{{selectedTemplate.notes}}</text>
    </view>
  </modal-sheet>

  <!-- 复制计划弹窗 -->
  <modal-sheet
    visible="{{showCloneModal}}"
    title="复制计划"
    description="为复制的计划指定一个新名称"
    confirmText="确认复制"
    cancelText="取消"
    bind:confirm="onConfirmClone"
    bind:cancel="onCancelClone"
    bind:close="onCancelClone"
  >
    <view class="input-wrapper">
      <text class="input-label">计划名称</text>
      <input class="input"
             placeholder="输入计划名称"
             value="{{newPlanName}}"
             bindinput="onInputPlanName" />
    </view>
  </modal-sheet>

  <!-- 计划推荐弹窗 -->
  <modal-sheet
    visible="{{showRecommendModal}}"
    title="为你推荐"
    description="{{recommendHasUserPrefs ? '基于你的目标和训练偏好，为你推荐最适合的计划' : '选择你的目标和时间，获取个性化推荐'}}"
    confirmText="应用推荐"
    cancelText="关闭"
    confirmDisabled="{{!selectedRecommendPlan}}"
    bind:confirm="onApplyRecommend"
    bind:cancel="onCloseRecommend"
    bind:close="onCloseRecommend"
  >
    <view wx:if="{{recommendedPlans.length === 0}}" class="recommend-empty">
      <text class="recommend-empty-text">暂无符合条件的推荐计划</text>
    </view>
    <view wx:else class="recommend-list">
      <view
        wx:for="{{recommendedPlans}}"
        wx:key="id"
        class="recommend-card {{selectedRecommendPlan === item.id ? 'selected' : ''}}"
        bindtap="onSelectRecommendPlan"
        data-id="{{item.id}}"
      >
        <view class="recommend-header">
          <text class="recommend-name">{{item.name}}</text>
          <view class="recommend-tags">
            <text class="tag template-difficulty {{item.difficultyClass}}">{{item.difficulty}}</text>
            <text class="tag">{{item.training_days}}天/周</text>
          </view>
        </view>
        <text class="recommend-desc">{{item.description}}</text>
        <view class="recommend-features">
          <text wx:for="{{item.features}}" wx:for-item="feat" wx:key="*this" class="feature-tag">{{feat}}</text>
        </view>
        <view wx:if="{{selectedRecommendPlan === item.id}}" class="recommend-check">✓ 已选择</view>
      </view>
    </view>
  </modal-sheet>
</view>
