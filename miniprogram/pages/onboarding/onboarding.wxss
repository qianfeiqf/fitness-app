/* 新用户引导页面样式 — WeUI 扁平风格 */

.page-onboarding {
  min-height: 100vh;
  min-height: 100dvh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* =====================
   进度条
   ===================== */
.onboarding-progress {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 48rpx;
  padding-top: 20rpx;
}

.progress-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 48rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #E5E5E5;
  transition: all 0.3s ease;
}

.dot.active {
  background: #1A1A1A;
  width: 64rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #999999;
}

/* =====================
   步骤头部
   ===================== */
.onboarding-step {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.step-header {
  margin-bottom: 48rpx;
}

.step-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
}

.step-subtitle {
  font-size: 28rpx;
  color: #666666;
  display: block;
}

/* =====================
   选项网格
   ===================== */
.option-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.option-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #E5E5E5;
  transition: all 0.2s ease;
  position: relative;
}

.option-card.selected {
  border-color: #07C160;
  background-color: #F8F8F8;
}

.option-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.option-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 22rpx;
  color: #999999;
  text-align: center;
  line-height: 1.4;
}

.option-check {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #1A1A1A;
  color: #FFFFFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* =====================
   天数选项
   ===================== */
.day-options {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.day-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 180rpx;
  height: 180rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #E5E5E5;
  transition: all 0.2s ease;
}

.day-card.selected {
  border-color: #07C160;
  background-color: #F8F8F8;
}

.day-number {
  font-size: 56rpx;
  font-weight: 700;
  color: #1A1A1A;
  font-family: 'DIN Alternate', system-ui, sans-serif;
  line-height: 1;
}

.day-label {
  font-size: 24rpx;
  color: #666666;
  margin-top: 4rpx;
}

.day-desc {
  font-size: 20rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* =====================
   经验选项
   ===================== */
.experience-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.exp-card {
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #E5E5E5;
  transition: all 0.2s ease;
}

.exp-card.selected {
  border-color: #07C160;
  background-color: #F8F8F8;
}

.exp-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.exp-icon {
  font-size: 48rpx;
}

.exp-info {
  display: flex;
  flex-direction: column;
}

.exp-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.exp-tag {
  font-size: 22rpx;
  color: #1A1A1A;
  background: #F0F0F0;
  padding: 2rpx 12rpx;
  border-radius: 9999rpx;
  margin-top: 4rpx;
  align-self: flex-start;
}

.exp-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

/* =====================
   推荐计划
   ===================== */
.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recommend-card {
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #E5E5E5;
  transition: all 0.2s ease;
}

.recommend-card.selected {
  border-color: #07C160;
  background-color: #F8F8F8;
}

.recommend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.recommend-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.recommend-tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  color: #666666;
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 9999rpx;
}

.tag.difficulty.beginner,
.tag.difficulty.intermediate,
.tag.difficulty.advanced {
  color: #1A1A1A;
  background: #F0F0F0;
}

.recommend-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.recommend-features {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.feature-tag {
  font-size: 20rpx;
  color: #1A1A1A;
  background: #F0F0F0;
  padding: 4rpx 12rpx;
  border-radius: 9999rpx;
}

.recommend-check {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 600;
}

/* =====================
   底部按钮
   ===================== */
.onboarding-footer {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 32rpx;
  padding-top: 16rpx;
}

.btn-back {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
}

.btn-spacer {
  width: 20rpx;
}
